    <string name="expiration_date">Срок на годност</string>
    <string name="expiration_date_reminder_help">Напомня, когато е достигнат срокът на годност на лекарството или конфигурируемо време преди тази дата.</string>
    <string name="inactive">Неактивно</string>
    <string name="interval_time">Интервал %s</string>
    <string name="linked_reminder">Свързано напомняне</string>
    <string name="linked_reminder_help">Свързаното напомняне е последващо напомняне, което се планира за определено време след предприемане на действие по основно напомняне (прието или отложено). Това е полезно за лекарства, които трябва да се приемат последователно, със специфично забавяне между тях.</string>
    <string name="linked_reminder_summary">След напомняне в %1$s</string>
    <string name="medicine_stock_string">Остават %1$s</string>
    <string name="out_of_stock_reminder">Напомняне за отъствие на запас</string>
    <string name="out_of_stock_reminder_help">Напомня, когато лекарството не е на склад, или след всяко напомняне, или веднъж, или веднъж на ден.</string>
    <string name="production_date">Дата на производство</string>
