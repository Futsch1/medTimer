<resources>
    <!-- Base application theme. -->
    <style name="Theme.MedTimer" parent="Theme.Material3.DynamicColors.Dark.NoActionBar">
        <item name="preferenceTheme">@style/MaterialPreferenceThemeOverlay</item>
    </style>

    <style name="Theme.MedTimer2" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/background_dark</item>
        <item name="colorSurfaceContainer">@android:color/background_dark</item>
        <item name="elevationOverlayColor">@android:color/background_dark</item>
    </style>



    <style name="MaterialPreferenceThemeOverlay" parent="PreferenceThemeOverlay">
        <item name="switchPreferenceCompatStyle">@style/Preference.SwitchPreferenceCompat</item>
    </style>

    <style name="Preference.SwitchPreferenceCompat" parent="Preference.SwitchPreferenceCompat.Material">
        <item name="android:widgetLayout">@layout/preference_widget_material_switch</item>
    </style>
</resources>