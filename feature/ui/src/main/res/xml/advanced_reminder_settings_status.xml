<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory>
    <SwitchPreferenceCompat app:key="period_start_switch" app:title="@string/period_start" />
    <Preference app:dependency="period_start_switch" app:title="@string/start_date" app:key="period_start_date"/>
    </PreferenceCategory>
    <PreferenceCategory>
    <SwitchPreferenceCompat app:key="period_end_switch" app:title="@string/period_end" />
    <Preference app:dependency="period_end_switch" app:title="@string/end_date" app:key="period_end_date" />
    </PreferenceCategory>
    <Preference
        app:allowDividerAbove="true"
        app:key="summary_only"
        app:summary="@string/reminder_status_summary" />
</androidx.preference.PreferenceScreen>