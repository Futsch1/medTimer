<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MedTimer.WidgetContainer" parent="Theme.MedTimer.WidgetContainerParent">
        <!-- Apply padding to avoid the content of the widget colliding with the rounded corners -->
        <item name="medtimerWidgetPadding">6dp</item>
    </style>

    <style name="Theme.MedTimer.WidgetContainerParent" parent="Theme.Material3.DynamicColors.Dark">
        <!-- Radius of the outer bound of widgets to make the rounded corners -->
        <item name="medtimerWidgetRadius">16dp</item>
        <!--
        Radius of the inner view's bound of widgets to make the rounded corners.
        It needs to be 8dp or less than the value of appWidgetRadius
        -->
        <item name="medtimerWidgetInnerRadius">8dp</item>
    </style>
</resources>
